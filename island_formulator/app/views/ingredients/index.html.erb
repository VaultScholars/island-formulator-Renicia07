<% content_for :title, "Ingredients" %>

<div class="container mx-auto mt-10 px-5">
  <div class="flex justify-between items-center mb-10">
    <h1 class="text-4xl font-extrabold text-yellow-950">My Ingredient Shelf</h1>
    <%= link_to "Add New Ingredient", new_ingredient_path, 
        class: "bg-orange-800 hover:bg-orange-200 text-white font-bold py-3 px-6 rounded-lg shadow-md transition duration-200" %>
  </div>

  <div id="ingredients" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
    <% @ingredients.each do |ingredient| %>
      <div class="bg-amber-100 shadow-lg rounded-xl p-6 border border-orange-200 hover:shadow-xl transition-shadow duration-300">
        <div class="mb-4">
          <span class="inline-block px-3 py-1 text-xs font-bold tracking-wide text-orange-900 uppercase bg-orange-200 rounded-full">
            <%= ingredient.category %>
          </span>
        </div>
        <h2 class="text-xl font-bold text-taupe-900 mb-2"><%= ingredient.name %></h2>
        <p class="text-orange-900 line-clamp-3 mb-4"><%= ingredient.description %></p>
        
        <div class="mt-auto pt-4 border-t border-taupe-900 flex justify-between items-center">
          <%= link_to "View Details", ingredient, class: "text-orange-600 font-medium hover:text-orange-900 transition-colors" %>
          <span class="text-lime-900 text-sm font-semibold">#<%= ingredient.id %></span>
        </div>
      </div>
    <% end %>
  </div>
</div>