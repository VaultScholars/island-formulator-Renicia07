<% content_for :title, "Batches" %>

<div class="w-full">
  <% if notice.present? %>
    <p class="py-2 px-3 bg-yellow-100 text-orange-950 font-medium rounded-lg inline-block mb-5" id="notice"><%= notice %></p>
  <% end %>

  <div class="flex justify-between items-center">
    <h1 class="font-bold text-4xl">Batch History</h1>
    <%= link_to "Log New Batch", new_batch_path, class: "rounded-lg py-3 px-5 bg-red-900 text-white block font-medium" %>
  </div>

  <div id="batches" class="min-w-full mt-8 grid grid-cols-1 md:grid-cols-2 gap-6">
    <% @batches.each do |batch| %>
      <div class="bg-amber-100 shadow rounded-lg p-6 border-l-4 border-lime-800">
        <div class="flex justify-between items-start">
          <div>
            <h2 class="font-bold text-xl text-orange-950"><%= batch.recipe.title %></h2>
            <p class="text-sm text-orange-950"><%= batch.made_on.strftime("%B %d, %Y") %></p>
          </div>
          <%= link_to "View Details", batch, class: "text-sm text-red-800 underline" %>
        </div>
        
        <% if batch.notes.present? %>
          <div class="mt-4 text-taupe-900 italic text-sm">
            "<%= batch.notes.truncate(100) %>"
          </div>
        <% end %>
      </div>
    <% end %>
    
    <% if @batches.empty? %>
      <p class="text-orange-900">No batches logged yet. Go make something!</p>
    <% end %>
  </div>
</div>