<% content_for :title, "Showing batch" %>

<div class="mx-auto md:w-2/3 w-full">
  <div class="bg-orange-100 shadow rounded-lg p-8 border-l-8 border-lime-800">
    <div class="flex justify-between items-start mb-8">
      <div>
        <p class="text-sm font-bold text-yellow-900 uppercase tracking-widest mb-1">Batch Log</p>
        <h1 class="font-bold text-4xl text-orange-950"><%= @batch.recipe.title %></h1>
        <p class="text-lg text-taupe-900 mt-2">Made on <%= @batch.made_on.strftime("%A, %B %d, %Y") %></p>
      </div>
      <%= link_to "View Recipe", @batch.recipe, class: "bg-red-200 text-red-900 px-4 py-2 rounded-lg font-medium hover:bg-blue-100" %>
    </div>

    <div class="mb-10">
      <h2 class="text-sm font-bold text-amber-900 uppercase tracking-widest mb-4">Ingredients Used</h2>
      <div class="bg-yellow-100 rounded-xl p-6">
        <ul class="divide-y divide-taupe-900">
          <% @batch.recipe.recipe_ingredients.each do |ri| %>
            <li class="py-3 flex justify-between">
              <span class="font-medium text-gray-800"><%= ri.ingredient.name %></span>
              <span class="text-gray-600"><%= ri.quantity %></span>
            </li>
          <% end %>
        </ul>
      </div>
    </div>

    <% if @batch.notes.present? %>
      <div class="mb-10">
        <h2 class="text-sm font-bold text-amber-900 uppercase tracking-widest mb-4">Production Notes</h2>
        <div class="prose prose-orange-950 max-w-none text-taupe-900 bg-yellow-100 p-6 rounded-xl italic">
          <%= simple_format @batch.notes %>
        </div>
      </div>
    <% end %>

    <div class="flex justify-between items-center pt-6 border-t border-yellow-900">
      <%= link_to "Back to History", batches_path, class: "text-amber-900 hover:underline font-medium" %>
      <div class="flex gap-3">
        <%= button_to "Delete Log", @batch, method: :delete, class: "text-red-900 text-sm font-bold hover:underline", data: { confirm: "Are you sure you want to delete this batch log?" } %>
      </div>
    </div>
  </div>
</div>