<% content_for :title, "Showing recipe" %>

<div class="md:w-2/3 w-full">
  <% if notice.present? %>
    <p class="py-2 px-3 bg-taupe-900 mb-5 text-mauve-950 font-medium rounded-md inline-block" id="notice"><%= notice %></p>
  <% end %>

  <h1 class="font-bold text-4xl text-yellow-950">Showing recipe</h1>

  <%= render @recipe %>

  <%= link_to "Edit this recipe", edit_recipe_path(@recipe), class: "w-full sm:w-auto text-center rounded-md px-3.5 py-2.5 text-taupe-900 bg-amber-100 hover:bg-orange-50 inline-block font-medium mb-4" %>
  <%= link_to "Back to recipes", recipes_path, class: "w-full sm:w-auto text-center rounded-md px-3.5 py-2.5 text-taupe-900 bg-amber-100 hover:bg-orange-50 inline-block font-medium" %>
  <%= button_to "Destroy this recipe", @recipe, method: :delete, form_class: "sm:inline-block mt-2 sm:mt-0 sm:ml-2", class: "w-full rounded-md px-3.5 py-2.5 text-white bg-red-900 hover:bg-red-600 font-medium cursor-pointer", data: { turbo_confirm: "Are you sure?" } %>
</div>

 <%# Add this button to quickly log a batch from the recipe page %>
  <%= link_to "Log a New Batch", new_batch_path(recipe_id: @recipe.id), 
      class: "w-full sm:w-auto text-center rounded-md px-3.5 py-2.5 text-taupe-900 bg-amber-100 hover:bg-orange-50 inline-block font-medium" %>
</div>

<div class="max-w-4xl mx-auto p-6">
  <div class="flex justify-between items-start mb-6">
    <div>
      <h1 class="text-4xl font-bold text-amber-950"><%= @recipe.title %></h1>
      <span class="inline-block bg-orange-300 text-yellow-950 text-xs px-2 py-1 rounded-full mt-2 font-semibold uppercase tracking-wide">
        <%= @recipe.product_type %>
      </span>
    </div>
    <div class="space-x-2">
      <%= link_to "Edit", edit_recipe_path(@recipe), class: "bg-red-900 text-white px-4 py-2 rounded hover:bg-red-600" %>
      <%= link_to "Back", recipes_path, class: "text-yellow-950 hover:underline" %>
    </div>
  </div>
  
  <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
    <div class="md:col-span-1">
      <% if @recipe.photo.attached? %>
        <%= image_tag @recipe.photo, class: "w-full h-auto object-cover rounded-xl shadow-lg border-4 border-orange-950/50" %>
      <% else %>
        <div class="w-full h-64 bg-orange-950/60 rounded-xl flex items-center justify-center text-taupe-500 italic">
          No photo uploaded
        </div>
      <% end %>
      
      <div class="mt-8 bg-white p-6 rounded-xl shadow-sm border border-gray-100">
        <h2 class="text-xl font-bold mb-4 text-yellow-950 border-b pb-2">Ingredients</h2>
        <ul class="space-y-3">
          <% @recipe.recipe_ingredients.each do |ri| %>
            <li class="flex justify-between items-center">
              <span class="font-medium text-taupe-950"><%= ri.ingredient.name %></span>
              <span class="text-gray-500 bg-taupe-950 px-2 py-1 rounded text-sm"><%= ri.quantity %></span>
            </li>
          <% end %>
        </ul>
      </div>
    </div>

    <div class="md:col-span-2">
      <div class="bg-white p-8 rounded-xl shadow-sm border border-gray-100 h-full">
        <h2 class="text-2xl font-bold mb-4 text-yellow-950">Method</h2>
        <div class="prose prose-green max-w-none text-taupe-950 leading-relaxed">
          <%= simple_format @recipe.method %>
        </div>
      </div>
    </div>
  </div>
</div>