<% content_for :title, "Recipes" %>

<div class="max-w-6xl mx-auto p-6">
  <div class="flex gap-2 mb-6">
    <h1 class="text-3xl font-bold text-yellow-950">My Recipes</h1>
    <%= link_to "New Recipe", new_recipe_path, class: "bg-red-900 text-white px-5 py-2 rounded-lg font-bold hover:bg-red-700" %>
    <%= link_to "My faves", favorites_path, class: "bg-red-900 text-white px-5 py-2 rounded-lg font-bold hover:bg-red-700" %>
  </div>

  <% if @recipes.empty? %>
    <div class="text-center py-12 bg-white rounded-lg shadow">
      <p class="text-taupe-950 mb-4">You haven't created any recipes yet.</p>
      <%= link_to "Create Your First Recipe", new_recipe_path, class: "text-taupe-950 font-semibold hover:underline" %>
    </div>
  <% else %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <% @recipes.each do |recipe| %>
        <div class="bg-amber-100 rounded-lg shadow hover:shadow-lg transition-shadow">
          <% if recipe.photo.attached? %>
            <%= image_tag recipe.photo, class: "w-full h-48 object-cover rounded-t-lg" %>
          <% else %>
            <div class="w-full h-48 bg-orange-950/60 rounded-t-lg flex items-center justify-center text-gray-400">
              No photo
            </div>
          <% end %>

      <div class="p-4">
        <div class="flex justify-between items-center">
          <h2 class="text-xl font-bold mb-2">
            <%= link_to recipe.title, recipe, class: "text-taupe-950 hover:text-stone-800" %>
          </h2>

        <% if current_user.favorited?(recipe) %>
          <%= button_to recipe_favorite_path(recipe), method: :delete,
            class: "bg-transparent border-none text-xl cursor-pointer" do %>
          ❤️
          <% end %>
        <% else %>
          <%= button_to recipe_favorite_path(recipe), method: :post,
            class: "bg-transparent border-none text-xl cursor-pointer" do %>
          🤍
        <% end %>
      <% end %>
  </div>

  <span class="inline-block bg-orange-200 text-yellow-800 text-xs px-2 py-1 rounded-full font-semibold uppercase tracking-wide">
    <%= recipe.product_type %>
  </span>

  <p class="text-yellow-800 text-sm mt-2">
    <%= pluralize(recipe.ingredients.count, 'ingredient') %>
  </p>
</div>
        </div>
      <% end %>
    </div>
  <% end %>
</div>